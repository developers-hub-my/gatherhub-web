# GatherHub Configuration
# Copy this file to .env.local and fill in your values

# The main application URL (for login/register links)
NEXT_PUBLIC_APP_URL=https://gatherhub.app

# Google Analytics 4 measurement ID (G-XXXXXXXXXX) — leave empty to disable
NEXT_PUBLIC_GA_ID=

# SparkPost (contact form email delivery)
SPARKPOST_API_KEY=
CONTACT_FORM_RECIPIENT=support@devhub.my
CONTACT_FORM_SENDER=noreply@devhub.my
